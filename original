      if (childActivity) {
        for (const [key, purposes] of Object.entries(ASSIST_PURPOSES_BY_ACTIVITY)) {
          if (childActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(childActivity.toLowerCase())) {
            return purposes;
          }
        }
      }

      // Then check parent activity
      if (parentActivity) {
        for (const [key, purposes] of Object.entries(ASSIST_PURPOSES_BY_ACTIVITY)) {
          if (parentActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(parentActivity.toLowerCase())) {
            return purposes;
          }
        }
      }

      return ASSIST_PURPOSES_BY_ACTIVITY['Default'];
    };

    const getPerformanceQualifiers = (parentActivity, childActivity) => {
      // Check child activity first for more specific match
      if (childActivity) {
        for (const [key, qualifiers] of Object.entries(PERFORMANCE_QUALIFIERS_BY_ACTIVITY)) {
          if (childActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(childActivity.toLowerCase())) {
            return qualifiers;
          }
        }
      }

      // Then check parent activity
      if (parentActivity) {
        for (const [key, qualifiers] of Object.entries(PERFORMANCE_QUALIFIERS_BY_ACTIVITY)) {
          if (parentActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(parentActivity.toLowerCase())) {
            return qualifiers;
          }
        }
      }

      return PERFORMANCE_QUALIFIERS_BY_ACTIVITY['Default'];
    };

    const getBodyPartsForActivity = (parentActivity, childActivity) => {
      // Check child activity first for more specific match
      if (childActivity) {
        for (const [key, bodyParts] of Object.entries(BODY_PARTS_BY_ACTIVITY)) {
          if (childActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(childActivity.toLowerCase())) {
            return bodyParts;
          }
        }
      }

      // Then check parent activity
      if (parentActivity) {
        for (const [key, bodyParts] of Object.entries(BODY_PARTS_BY_ACTIVITY)) {
          if (parentActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(parentActivity.toLowerCase())) {
            return bodyParts;
          }
        }
      }

      return BODY_PARTS_BY_ACTIVITY['Default'];
    };

    const getCueContextsForActivity = (parentActivity, childActivity) => {
      // Check child activity first for more specific match
      if (childActivity) {
        for (const [key, contexts] of Object.entries(CUE_CONTEXTS)) {
          if (childActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(childActivity.toLowerCase())) {
            return contexts;
          }
        }
      }

      // Then check parent activity
      if (parentActivity) {
        for (const [key, contexts] of Object.entries(CUE_CONTEXTS)) {
          if (parentActivity.toLowerCase().includes(key.toLowerCase()) ||
              key.toLowerCase().includes(parentActivity.toLowerCase())) {
            return contexts;
          }
        }
      }

      return CUE_CONTEXTS['Default'];
    };

    // ============================================
    // UI COMPONENTS
    // ============================================

    const ChipButton = ({ selected, onClick, children, variant = 'default', size = 'md' }) => {
      const sizeStyles = {
        sm: { padding: '4px 8px', fontSize: '11px', borderRadius: '4px' },
        md: { padding: '5px 10px', fontSize: '12px', borderRadius: '5px' },
        lg: { padding: '6px 12px', fontSize: '13px', borderRadius: '6px' }
      };

      const variantStyles = {
        default: {
          background: selected ? 'var(--accent-primary)' : 'var(--chip-bg)',
          color: selected ? '#fff' : 'var(--text-primary)',
          border: 'none'
        },
        outline: {
          background: selected ? 'var(--accent-light)' : 'transparent',
          color: selected ? 'var(--accent-primary)' : 'var(--text-secondary)',
          border: `1px solid ${selected ? 'var(--accent-primary)' : 'var(--border-color)'}`
        }
      };

      return (
        <button
          onClick={onClick}
          style={{
            display: 'inline-flex',
            alignItems: 'center',
            justifyContent: 'center',
            cursor: 'pointer',
            fontFamily: 'inherit',
            fontWeight: 500,
            transition: 'all 0.12s ease',
            whiteSpace: 'nowrap',
            textAlign: 'left',
            ...sizeStyles[size],
            ...variantStyles[variant]
          }}
        >
          {children}
        </button>
      );
    };

    const SectionHeader = ({ children }) => (
      <div style={{
        fontSize: '10px',
        fontWeight: 600,
        textTransform: 'uppercase',
        letterSpacing: '0.5px',
        color: 'var(--text-muted)',
        marginBottom: '8px'
      }}>
        {children}
      </div>
    );

    const OptionGrid = ({ children, columns = 2 }) => (
      <div style={{
        display: 'grid',
        gridTemplateColumns: `repeat(${columns}, 1fr)`,
        gap: '4px'
      }}>
        {children}
      </div>
    );

    const STEPS = [
      { id: 'cpt', label: 'CPT', required: true },
      { id: 'activity', label: 'Activity', required: true },
      { id: 'goal', label: 'Goal', required: true },
      { id: 'support', label: 'Support', required: false },
      { id: 'response', label: 'Response', required: false },
      { id: 'notes', label: 'Notes', required: false }
    ];

    // ============================================
    // MAIN APPLICATION
    // ============================================

    const OTDailyNoteBuilder = () => {
      const [currentStep, setCurrentStep] = useState(0);
      const [cptCode, setCptCode] = useState(null);
      const [activity, setActivity] = useState({ parent: null, child: null, params: { sets: '', reps: '', equipment: '' } });
      const [goal, setGoal] = useState(null);
      const [assists, setAssists] = useState([]);
      const [newAssist, setNewAssist] = useState({ level: '', location: '', purpose: '', modifier: '' });
      const [editingAssistIndex, setEditingAssistIndex] = useState(null);
      const [cues, setCues] = useState([]);
      const [deficit, setDeficit] = useState(null);
      const [progress, setProgress] = useState(null);
      const [tolerance, setTolerance] = useState(null);
      const [plan, setPlan] = useState(null);
      const [selectedPerformance, setSelectedPerformance] = useState([]);
      const [selectedContext, setSelectedContext] = useState([]);
      const [selectedReasoning, setSelectedReasoning] = useState([]);
      const [patientSubjective, setPatientSubjective] = useState('');
      const [painLocation, setPainLocation] = useState('');
      const [painRating, setPainRating] = useState('');
      const [vitals, setVitals] = useState({ hr: '', o2sat: '', bp: '' });
      const [outputStyle, setOutputStyle] = useState('goal');
      const [copied, setCopied] = useState(false);
      const [activityModalStep, setActivityModalStep] = useState('parent');
      const [selectedParent, setSelectedParent] = useState(null);
      const [selectedSubCategory, setSelectedSubCategory] = useState(null);
      const [newCue, setNewCue] = useState({ level: '', type: '', bodyPart: '', purpose: '', context: '' });
      const [editingCueIndex, setEditingCueIndex] = useState(null);
      const [showAllGoals, setShowAllGoals] = useState(false);
      const [showAllAssistPurposes, setShowAllAssistPurposes] = useState(false);
      const [savedNotes, setSavedNotes] = useState([]);
      const [darkMode, setDarkMode] = useState(() => {
        const saved = localStorage.getItem('otNoteDarkMode');
        return saved === 'true';
      });

      useEffect(() => {
        document.documentElement.setAttribute('data-theme', darkMode ? 'dark' : 'light');
        localStorage.setItem('otNoteDarkMode', darkMode);
      }, [darkMode]);

      useEffect(() => {
        try {
          const saved = localStorage.getItem('otNoteHistory');
          if (saved) setSavedNotes(JSON.parse(saved));
        } catch (e) { console.error('Failed to load history:', e); }
      }, []);

      const getActivitiesForCPT = useCallback(() => {
        if (!cptCode) return {};
        return ACTIVITIES_BY_CPT[cptCode] || {};
      }, [cptCode]);

      const filteredGoals = useMemo(() => {
        if (showAllGoals) return GOALS;
        const relevantIds = getGoalsForActivity(activity.parent, activity.child);
        return GOALS.filter(g => relevantIds.includes(g.id));
      }, [activity.parent, activity.child, showAllGoals]);

      const deficitOptions = useMemo(() => getDeficitsForActivity(activity.parent), [activity.parent]);
      const relevantAssistPurposes = useMemo(() => getAssistPurposesForActivity(activity.parent, activity.child), [activity.parent, activity.child]);
      const assistPurposeOptions = showAllAssistPurposes ? ASSIST_PURPOSES : relevantAssistPurposes;
      const cueBodyPartOptions = useMemo(() => getBodyPartsForActivity(activity.parent, activity.child), [activity.parent, activity.child]);
      const cueContextOptions = useMemo(() => getCueContextsForActivity(activity.parent, activity.child), [activity.parent, activity.child]);

      const buildClinicianAnalysis = useCallback(() => {
        const parts = [];
        if (selectedPerformance.length > 0) {
          parts.push(selectedPerformance.length === 1 ? `Patient performed task ${selectedPerformance[0]}` : `Patient demonstrated ${selectedPerformance.join(' and ')} performance patterns`);
        }
        if (selectedContext.length > 0) parts.push(...selectedContext.map(ctx => ctx + ', which influenced therapeutic approach'));
        if (selectedReasoning.length > 0) parts.push(...selectedReasoning.map(r => r + ' based on clinical assessment'));
        return parts.join('. ') + (parts.length > 0 ? '.' : '');
      }, [selectedPerformance, selectedContext, selectedReasoning]);

      const buildOutput = useCallback(() => {
        const parts = [];
        let activityStr = '';
        if (activity.child) {
          activityStr = activity.child;
          const params = [];
          if (activity.params.sets && activity.params.reps) params.push(`${activity.params.sets}x${activity.params.reps}`);
          else if (activity.params.sets) params.push(`${activity.params.sets} sets`);
          else if (activity.params.reps) params.push(`${activity.params.reps} reps`);
          if (activity.params.equipment) params.push(activity.params.equipment.toLowerCase());
          if (params.length) activityStr += ` (${params.join(', ')})`;
        }

        const goalPhrase = goal ? GOALS.find(g => g.id === goal)?.phrase : '';
        const assistPhrases = assists.map(a => {
          const level = ASSIST_LEVELS.find(l => l.id === a.level);
          if (!level) return '';
          if (a.level === 'I') return 'Independent';
          if (a.level === 'ModI') return 'Modified independent' + (a.modifier ? ` ${a.modifier}` : '');
          if (a.level === 'S') return 'Supervision' + (a.purpose ? ` ${a.purpose}` : '');
          if (a.level === 'CGA') return 'CGA' + (a.purpose ? ` ${a.purpose}` : '');
          let phrase = level.full;
          if (a.location) phrase += ` ${a.location}`;
          if (a.purpose) phrase += ` ${a.purpose}`;
          return phrase;
        }).filter(Boolean);

        const cuePhrases = cues.map(c => {
          let phrase = `${c.level} ${c.type} cues`;
          if (c.bodyPart) phrase += ` to ${c.bodyPart}`;
          if (c.purpose) phrase += ` for ${c.purpose}`;
          if (c.context) phrase += ` during ${c.context}`;
          return phrase.toLowerCase();
        });

        const deficitPhrase = deficit ? deficit.charAt(0).toLowerCase() + deficit.slice(1) : '';
        const progressData = progress ? PROGRESS_OPTIONS.find(p => p.id === progress) : null;
        const tolerancePhrase = tolerance ? TOLERANCE_OPTIONS.find(t => t.id === tolerance)?.phrase : '';
        const planPhrase = plan ? PLAN_OPTIONS.find(p => p.id === plan)?.phrase : '';

        if (outputStyle === 'goal') {
          if (goalPhrase && activityStr) parts.push(`To ${goalPhrase}, patient instructed in ${activityStr}.`);
          if (deficitPhrase) parts.push(`${deficit} noted.`);
          if (assistPhrases.length || cuePhrases.length) {
            const combined = [...assistPhrases, ...cuePhrases].filter(Boolean);
            if (combined.length === 1) parts.push(`${combined[0]} required.`);
            else if (combined.length > 1) { const last = combined.pop(); parts.push(`${combined.join(', ')}, and ${last} required.`); }
          }
          if (progressData) parts.push(progressData.goalLed + '.');
          if (tolerancePhrase) parts.push(tolerancePhrase + '.');
          if (planPhrase) parts.push(planPhrase + '.');
        } else {
          if (activityStr && goalPhrase) {
            let sentence = `Patient performed ${activityStr}`;
            if (assistPhrases.length || cuePhrases.length) {
              const combined = [...assistPhrases, ...cuePhrases].filter(Boolean);
              if (combined.length === 1) sentence += ` with ${combined[0]}`;
              else if (combined.length > 1) { const last = combined.pop(); sentence += ` with ${combined.join(', ')}, and ${last}`; }
            }
            sentence += ` to ${goalPhrase}.`;
            parts.push(sentence);
          }
          if (progressData && deficitPhrase) parts.push(`${progressData.activityLed}. Assistance required 2/2 ${deficitPhrase}.`);
          else if (progressData) parts.push(progressData.activityLed + '.');
          else if (deficitPhrase) parts.push(`Assistance required 2/2 ${deficitPhrase}.`);
          if (tolerancePhrase) parts.push(tolerancePhrase + '.');
          if (planPhrase) parts.push(planPhrase + '.');
        }

        const clinicalAnalysis = buildClinicianAnalysis();
        if (clinicalAnalysis.trim()) parts.push(clinicalAnalysis.trim());

        const responseItems = [];
        if (patientSubjective.trim()) responseItems.push(`Patient reports: "${patientSubjective.trim()}"`);
        if (painLocation.trim() && painRating.trim()) responseItems.push(`Pain reported ${painRating}/10 at ${painLocation.trim()}`);
        else if (painRating.trim()) responseItems.push(`Pain reported ${painRating}/10`);
        const vitalsList = [];
        if (vitals.hr) vitalsList.push(`HR: ${vitals.hr}`);
        if (vitals.o2sat) vitalsList.push(`O2 Sat: ${vitals.o2sat}%`);
        if (vitals.bp) vitalsList.push(`BP: ${vitals.bp}`);
        if (vitalsList.length > 0) responseItems.push(`Vitals: ${vitalsList.join(', ')}`);
        if (responseItems.length > 0) parts.push(responseItems.join('. ') + '.');

        return parts.join(' ');
      }, [activity, goal, assists, cues, deficit, progress, tolerance, plan, selectedPerformance, selectedContext, selectedReasoning, patientSubjective, painLocation, painRating, vitals, outputStyle, buildClinicianAnalysis]);

      const output = useMemo(() => buildOutput(), [buildOutput]);

      const handleCopy = async () => {
        try {
          await navigator.clipboard.writeText(output);
          setCopied(true);
          setTimeout(() => setCopied(false), 2000);
          const newNote = { id: generateId(), timestamp: new Date().toISOString(), cptCode, goal, activity, assists, cues, deficit, progress, tolerance, plan, selectedPerformance, selectedContext, selectedReasoning, patientSubjective, painLocation, painRating, vitals, outputStyle, outputText: output };
          const updatedNotes = [newNote, ...savedNotes].slice(0, 20);
          setSavedNotes(updatedNotes);
          try { localStorage.setItem('otNoteHistory', JSON.stringify(updatedNotes)); } catch (e) { console.error('Storage full:', e); }
        } catch (e) { console.error('Failed to copy:', e); }
      };

      const handleClear = () => {
        setCptCode(null); setActivity({ parent: null, child: null, params: { sets: '', reps: '', equipment: '' } });
        setGoal(null); setAssists([]); setNewAssist({ level: '', location: '', purpose: '', modifier: '' });
        setEditingAssistIndex(null); setCues([]); setDeficit(null); setProgress(null); setTolerance(null);
        setPlan(null); setSelectedPerformance([]); setSelectedContext([]); setSelectedReasoning([]);
        setPatientSubjective(''); setPainLocation(''); setPainRating(''); setVitals({ hr: '', o2sat: '', bp: '' });
        setCurrentStep(0); setActivityModalStep('parent'); setSelectedParent(null); setSelectedSubCategory(null);
      };

      const handleCPTSelect = (code) => {
        if (cptCode !== code) {
          setCptCode(code); setActivity({ parent: null, child: null, params: { sets: '', reps: '', equipment: '' } });
          setGoal(null); setDeficit(null); setActivityModalStep('parent'); setSelectedParent(null); setSelectedSubCategory(null);
        }
        setTimeout(() => setCurrentStep(1), 100);
      };

      const handleParentSelect = (parent) => {
        setSelectedParent(parent);
        const activities = getActivitiesForCPT();
        const children = activities[parent];
        if (cptCode === '97535' && typeof children === 'object' && !Array.isArray(children)) setActivityModalStep('subcategory');
        else setActivityModalStep('child');
      };

      const handleSubCategorySelect = (subcat) => { setSelectedSubCategory(subcat); setActivityModalStep('child'); };

      const handleChildSelect = (child) => {
        setActivity(prev => ({ ...prev, parent: selectedParent, child }));
        setActivityModalStep('params');
      };

      const handleAddAssist = () => {
        if (newAssist.level) {
          if (editingAssistIndex !== null) {
            setAssists(prev => prev.map((a, i) => i === editingAssistIndex ? { ...newAssist, id: a.id } : a));
            setEditingAssistIndex(null);
          } else { setAssists(prev => [...prev, { ...newAssist, id: generateId() }]); }
          setNewAssist({ level: '', location: '', purpose: '', modifier: '' });
        }
      };

      const handleRemoveAssist = (index) => setAssists(prev => prev.filter((_, i) => i !== index));
      const handleEditAssist = (index) => { setNewAssist(assists[index]); setEditingAssistIndex(index); };
      const handleCancelAssistEdit = () => { setNewAssist({ level: '', location: '', purpose: '', modifier: '' }); setEditingAssistIndex(null); };

      const handleAddCue = () => {
        if (newCue.level && newCue.type) {
          if (editingCueIndex !== null) {
            setCues(prev => prev.map((c, i) => i === editingCueIndex ? { ...newCue, id: c.id } : c));
            setEditingCueIndex(null);
          } else { setCues(prev => [...prev, { ...newCue, id: generateId() }]); }
          setNewCue({ level: '', type: '', bodyPart: '', purpose: '', context: '' });
        }
      };

      const handleRemoveCue = (index) => setCues(prev => prev.filter((_, i) => i !== index));
      const handleEditCue = (index) => { setNewCue(cues[index]); setEditingCueIndex(index); };
      const handleCancelCueEdit = () => { setNewCue({ level: '', type: '', bodyPart: '', purpose: '', context: '' }); setEditingCueIndex(null); };

      const getChildrenForSelection = () => {
        const activities = getActivitiesForCPT();
        if (!selectedParent) return { short: [], phrases: [] };
        const children = activities[selectedParent];
        if (Array.isArray(children)) return { short: children, phrases: [] };
        if (selectedSubCategory && children[selectedSubCategory]) {
          const subData = children[selectedSubCategory];
          // Check if it's the new structure with short/phrases
          if (subData && typeof subData === 'object' && !Array.isArray(subData) && ('short' in subData || 'phrases' in subData)) {
            return { short: subData.short || [], phrases: subData.phrases || [] };
          }
          // Old structure - just an array
          if (Array.isArray(subData)) return { short: subData, phrases: [] };
        }
        return { short: [], phrases: [] };
      };

      const getSubCategories = () => {
        const activities = getActivitiesForCPT();
        if (!selectedParent) return [];
        const children = activities[selectedParent];
        if (typeof children === 'object' && !Array.isArray(children)) return Object.keys(children);
        return [];
      };

      const canProceed = () => {
        switch (STEPS[currentStep].id) {
          case 'cpt': return !!cptCode;
          case 'activity': return !!activity.child;
          case 'goal': return !!goal;
          default: return true;
        }
      };

      const handleNext = () => { if (currentStep < STEPS.length - 1) setCurrentStep(prev => prev + 1); };
      const handleBack = () => {
        // If we're in the activity step, handle internal navigation first
        if (STEPS[currentStep].id === 'activity') {
          if (activityModalStep === 'params') {
            setActivityModalStep('child');
            return;
          }
          if (activityModalStep === 'child') {
            if (selectedSubCategory) {
              setActivityModalStep('subcategory');
              setSelectedSubCategory(null);
            } else {
              setActivityModalStep('parent');
              setSelectedParent(null);
            }
            return;
          }
          if (activityModalStep === 'subcategory') {
            setActivityModalStep('parent');
            setSelectedParent(null);
            setSelectedSubCategory(null);
            return;
          }
        }
        // Otherwise go to previous step
        if (currentStep > 0) setCurrentStep(prev => prev - 1);
      };

      // ============================================
      // RENDER STAGE CONTENT
      // ============================================

      const renderStageContent = () => {
        const stepId = STEPS[currentStep].id;

        switch (stepId) {
          case 'cpt':
            return (
              <div>
                <SectionHeader>Select CPT Code</SectionHeader>
                <OptionGrid columns={2}>
                  {CPT_CODES.map(cpt => (
                    <ChipButton key={cpt.code} selected={cptCode === cpt.code} onClick={() => handleCPTSelect(cpt.code)} size="md">
                      {cpt.code} — {cpt.label}
                    </ChipButton>
                  ))}
                </OptionGrid>
              </div>
            );

          case 'activity':
            return (
              <div>
                <SectionHeader>
                  {activityModalStep === 'parent' && 'Select Activity Category'}
                  {activityModalStep === 'subcategory' && `${selectedParent} — Select Sub-Category`}
                  {activityModalStep === 'child' && `${selectedParent}${selectedSubCategory ? ` → ${selectedSubCategory}` : ''} — Select Activity`}
                  {activityModalStep === 'params' && 'Activity Parameters (Optional)'}
                </SectionHeader>

                {activityModalStep === 'parent' && (
                  <OptionGrid columns={2}>
                    {Object.keys(getActivitiesForCPT()).map(parent => (
                      <ChipButton key={parent} selected={false} onClick={() => handleParentSelect(parent)} size="md">{parent}</ChipButton>
                    ))}
                  </OptionGrid>
                )}

                {activityModalStep === 'subcategory' && (
                  <OptionGrid columns={2}>
                    {getSubCategories().map(subcat => (<ChipButton key={subcat} selected={false} onClick={() => handleSubCategorySelect(subcat)} size="md">{subcat}</ChipButton>))}
                  </OptionGrid>
                )}

                {activityModalStep === 'child' && (() => {
                  const { short, phrases } = getChildrenForSelection();
                  const hasPhases = phrases.length > 0;
                  const hasShort = short.length > 0;

                  if (hasPhases && hasShort) {
                    // Two-column layout
                    return (
                      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px' }}>
                        <div>
                          <div style={{ fontSize: '10px', fontWeight: 600, color: 'var(--text-muted)', marginBottom: '6px', textTransform: 'uppercase' }}>Activities</div>
                          <div style={{ display: 'flex', flexDirection: 'column', gap: '4px' }}>
                            {short.map(child => (<ChipButton key={child} selected={activity.child === child} onClick={() => handleChildSelect(child)} size="sm">{child}</ChipButton>))}
                          </div>
                        </div>
                        <div>
                          <div style={{ fontSize: '10px', fontWeight: 600, color: 'var(--text-muted)', marginBottom: '6px', textTransform: 'uppercase' }}>Intervention Phrases</div>
                          <div style={{ display: 'flex', flexDirection: 'column', gap: '4px', maxHeight: '300px', overflowY: 'auto' }}>
                            {phrases.map(child => (<ChipButton key={child} selected={activity.child === child} onClick={() => handleChildSelect(child)} size="sm" style={{ textAlign: 'left', whiteSpace: 'normal', height: 'auto', padding: '6px 10px' }}>{child}</ChipButton>))}
                          </div>
                        </div>
                      </div>
                    );
                  } else if (hasPhases) {
                    // Only phrases
                    return (
                      <div style={{ display: 'flex', flexDirection: 'column', gap: '4px', maxHeight: '350px', overflowY: 'auto' }}>
                        {phrases.map(child => (<ChipButton key={child} selected={activity.child === child} onClick={() => handleChildSelect(child)} size="sm" style={{ textAlign: 'left', whiteSpace: 'normal', height: 'auto', padding: '6px 10px' }}>{child}</ChipButton>))}
                      </div>
                    );
                  } else {
                    // Only short activities (or other CPT codes)
                    return (
                      <OptionGrid columns={2}>
                        {short.map(child => (<ChipButton key={child} selected={activity.child === child} onClick={() => handleChildSelect(child)} size="md">{child}</ChipButton>))}
                      </OptionGrid>
                    );
                  }
                })()}

                {activityModalStep === 'params' && (
                  <div>
                    <div style={{ background: 'var(--accent-light)', padding: '8px 12px', borderRadius: '6px', marginBottom: '12px', color: 'var(--accent-primary)', fontWeight: 500, fontSize: '12px' }}>
                      {activity.parent} → {activity.child}
                    </div>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '8px', marginBottom: '12px' }}>
                      <div>
                        <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '2px' }}>Sets</label>
                        <input type="number" value={activity.params.sets} onChange={(e) => setActivity(prev => ({ ...prev, params: { ...prev.params, sets: e.target.value } }))} placeholder="3" style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '12px' }} />
                      </div>
                      <div>
                        <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '2px' }}>Reps</label>
                        <input type="number" value={activity.params.reps} onChange={(e) => setActivity(prev => ({ ...prev, params: { ...prev.params, reps: e.target.value } }))} placeholder="10" style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '12px' }} />
                      </div>
                      <div>
                        <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '2px' }}>Equipment</label>
                        <select value={activity.params.equipment} onChange={(e) => setActivity(prev => ({ ...prev, params: { ...prev.params, equipment: e.target.value } }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '12px' }}>
                          <option value="">None</option>
                          {getEquipmentForActivity(activity.parent).map(eq => (<option key={eq} value={eq}>{eq}</option>))}
                        </select>
                      </div>
                    </div>
                    <button onClick={() => { setActivityModalStep('parent'); setSelectedParent(null); setSelectedSubCategory(null); }} style={{ padding: '4px 10px', background: 'none', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: 'pointer', fontSize: '11px', color: 'var(--text-secondary)' }}>Change Activity</button>
                  </div>
                )}
              </div>
            );

          case 'goal':
            return (
              <div>
                <SectionHeader>Select Goal</SectionHeader>
                <OptionGrid columns={2}>
                  {filteredGoals.map(g => (
                    <ChipButton key={g.id} selected={goal === g.id} onClick={() => { const newGoal = goal === g.id ? null : g.id; setGoal(newGoal); if (newGoal) setTimeout(() => setCurrentStep(3), 100); }} size="sm">
                      {g.phrase}
                    </ChipButton>
                  ))}
                </OptionGrid>
                {!showAllGoals && filteredGoals.length < GOALS.length && (
                  <button onClick={() => setShowAllGoals(true)} style={{ background: 'none', border: 'none', color: 'var(--accent-primary)', fontSize: '11px', cursor: 'pointer', marginTop: '8px' }}>
                    Show all goals ({GOALS.length - filteredGoals.length} more)
                  </button>
                )}
                {showAllGoals && (
                  <button onClick={() => setShowAllGoals(false)} style={{ background: 'none', border: 'none', color: 'var(--text-muted)', fontSize: '11px', cursor: 'pointer', marginTop: '8px' }}>Show relevant only</button>
                )}
              </div>
            );

          case 'support':
            return (
              <div>
                <SectionHeader>Assist Levels</SectionHeader>
                {assists.length > 0 && (
                  <div style={{ marginBottom: '10px', display: 'flex', flexWrap: 'wrap', gap: '4px' }}>
                    {assists.map((assist, index) => {
                      const level = ASSIST_LEVELS.find(l => l.id === assist.level);
                      let display = level?.full || assist.level;
                      if (assist.level === 'ModI' && assist.modifier) display += ` ${assist.modifier}`;
                      else { if (assist.location) display += ` ${assist.location}`; if (assist.purpose) display += ` ${assist.purpose}`; }
                      return (
                        <div key={assist.id} style={{ display: 'inline-flex', alignItems: 'center', gap: '4px', background: 'var(--accent-light)', padding: '3px 8px', borderRadius: '4px', border: '1px solid var(--accent-primary)', fontSize: '11px', color: 'var(--accent-primary)' }}>
                          <span>{display}</span>
                          <button onClick={() => handleEditAssist(index)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--accent-primary)', fontSize: '10px' }}>✎</button>
                          <button onClick={() => handleRemoveAssist(index)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--accent-primary)', fontSize: '12px' }}>×</button>
                        </div>
                      );
                    })}
                  </div>
                )}

                <div style={{ background: 'var(--bg-tertiary)', padding: '10px', borderRadius: '6px', marginBottom: '12px' }}>
                  <div style={{ fontWeight: 600, fontSize: '11px', marginBottom: '8px' }}>{editingAssistIndex !== null ? 'Edit Assist' : 'Add Assist'}</div>
                  <div style={{ marginBottom: '8px' }}>
                    <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Level *</label>
                    <OptionGrid columns={4}>
                      {ASSIST_LEVELS.map(level => (<ChipButton key={level.id} selected={newAssist.level === level.id} onClick={() => setNewAssist(prev => ({ ...prev, level: level.id, location: '', purpose: '', modifier: '' }))} size="sm">{level.label}</ChipButton>))}
                    </OptionGrid>
                  </div>

                  {newAssist.level === 'ModI' && (
                    <div style={{ marginBottom: '8px' }}>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Modifier</label>
                      <select value={newAssist.modifier} onChange={(e) => setNewAssist(prev => ({ ...prev, modifier: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Select...</option>
                        {MODI_MODIFIERS.map(mod => (<option key={mod} value={mod}>{mod}</option>))}
                      </select>
                    </div>
                  )}

                  {newAssist.level && !['I', 'ModI'].includes(newAssist.level) && (
                    <div style={{ display: 'grid', gridTemplateColumns: newAssist.level === 'S' ? '1fr' : '1fr 1fr', gap: '8px', marginBottom: '8px' }}>
                      {newAssist.level !== 'S' && (
                        <div>
                          <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Location</label>
                          <select value={newAssist.location} onChange={(e) => setNewAssist(prev => ({ ...prev, location: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                            <option value="">Optional...</option>
                            {getAssistLocationsForActivity(activity.parent, activity.child).map(loc => (<option key={loc} value={loc}>{loc}</option>))}
                          </select>
                        </div>
                      )}
                      <div>
                        <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Purpose</label>
                        <select value={newAssist.purpose} onChange={(e) => setNewAssist(prev => ({ ...prev, purpose: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                          <option value="">Optional...</option>
                          {assistPurposeOptions.map(p => (<option key={p} value={p}>{p}</option>))}
                        </select>
                      </div>
                    </div>
                  )}

                  <div style={{ display: 'flex', gap: '6px' }}>
                    {editingAssistIndex !== null && (<button onClick={handleCancelAssistEdit} style={{ flex: 1, padding: '6px', background: 'var(--bg-secondary)', color: 'var(--text-secondary)', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: 'pointer', fontSize: '11px' }}>Cancel</button>)}
                    <button onClick={handleAddAssist} disabled={!newAssist.level} style={{ flex: 1, padding: '6px', background: newAssist.level ? 'var(--accent-primary)' : 'var(--bg-tertiary)', color: newAssist.level ? '#fff' : 'var(--text-muted)', border: 'none', borderRadius: '4px', cursor: newAssist.level ? 'pointer' : 'not-allowed', fontSize: '11px', fontWeight: 500 }}>
                      {editingAssistIndex !== null ? 'Update' : 'Add Assist'}
                    </button>
                  </div>
                </div>

                <SectionHeader>Cues</SectionHeader>
                {cues.length > 0 && (
                  <div style={{ marginBottom: '10px', display: 'flex', flexWrap: 'wrap', gap: '4px' }}>
                    {cues.map((cue, index) => (
                      <div key={cue.id} style={{ display: 'inline-flex', alignItems: 'center', gap: '4px', background: 'var(--accent-light)', padding: '3px 8px', borderRadius: '4px', border: '1px solid var(--accent-primary)', fontSize: '11px', color: 'var(--accent-primary)' }}>
                        <span>{cue.level} {cue.type}{cue.bodyPart && ` to ${cue.bodyPart}`}{cue.purpose && ` for ${cue.purpose}`}</span>
                        <button onClick={() => handleEditCue(index)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--accent-primary)', fontSize: '10px' }}>✎</button>
                        <button onClick={() => handleRemoveCue(index)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--accent-primary)', fontSize: '12px' }}>×</button>
                      </div>
                    ))}
                  </div>
                )}

                <div style={{ background: 'var(--bg-tertiary)', padding: '10px', borderRadius: '6px' }}>
                  <div style={{ fontWeight: 600, fontSize: '11px', marginBottom: '8px' }}>{editingCueIndex !== null ? 'Edit Cue' : 'Add Cue'}</div>
                  <div style={{ marginBottom: '8px' }}>
                    <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Quick-add common cues:</label>
                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: '4px' }}>
                      {[['Min', 'verbal'], ['Mod', 'verbal'], ['Min', 'tactile'], ['Mod', 'tactile'], ['Min', 'visual'], ['Mod', 'verbal/tactile']].map(([lvl, typ]) => (
                        <button key={`${lvl}-${typ}`} onClick={() => { if (editingCueIndex === null) { setCues(prev => [...prev, { level: lvl, type: typ, bodyPart: '', purpose: '', context: '', id: generateId() }]); }}} style={{ padding: '4px 8px', background: 'var(--bg-secondary)', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: 'pointer', fontSize: '10px' }}>{lvl} {typ}</button>
                      ))}
                    </div>
                  </div>
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '8px', marginBottom: '8px' }}>
                    <div>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Level *</label>
                      <select value={newCue.level} onChange={(e) => setNewCue(prev => ({ ...prev, level: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Select...</option>
                        {CUE_LEVELS.map(l => (<option key={l} value={l}>{l}</option>))}
                      </select>
                    </div>
                    <div>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>Type *</label>
                      <select value={newCue.type} onChange={(e) => setNewCue(prev => ({ ...prev, type: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Select...</option>
                        {CUE_TYPES.map(t => (<option key={t} value={t}>{t}</option>))}
                      </select>
                    </div>
                  </div>
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '8px', marginBottom: '8px' }}>
                    <div>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>To (body)</label>
                      <select value={newCue.bodyPart} onChange={(e) => setNewCue(prev => ({ ...prev, bodyPart: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Optional</option>
                        {cueBodyPartOptions.map(bp => (<option key={bp} value={bp}>{bp}</option>))}
                      </select>
                    </div>
                    <div>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>For (purpose)</label>
                      <select value={newCue.purpose} onChange={(e) => setNewCue(prev => ({ ...prev, purpose: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Optional</option>
                        {CUE_PURPOSES.map(p => (<option key={p} value={p}>{p}</option>))}
                      </select>
                    </div>
                    <div>
                      <label style={{ display: 'block', fontSize: '10px', color: 'var(--text-muted)', marginBottom: '3px' }}>During</label>
                      <select value={newCue.context} onChange={(e) => setNewCue(prev => ({ ...prev, context: e.target.value }))} style={{ width: '100%', padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Optional</option>
                        {cueContextOptions.map(c => (<option key={c} value={c}>{c}</option>))}
                      </select>
                    </div>
                  </div>
                  <div style={{ display: 'flex', gap: '6px' }}>
                    {editingCueIndex !== null && (<button onClick={handleCancelCueEdit} style={{ flex: 1, padding: '6px', background: 'var(--bg-secondary)', color: 'var(--text-secondary)', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: 'pointer', fontSize: '11px' }}>Cancel</button>)}
                    <button onClick={handleAddCue} disabled={!newCue.level || !newCue.type} style={{ flex: 1, padding: '6px', background: newCue.level && newCue.type ? 'var(--accent-primary)' : 'var(--bg-tertiary)', color: newCue.level && newCue.type ? '#fff' : 'var(--text-muted)', border: 'none', borderRadius: '4px', cursor: newCue.level && newCue.type ? 'pointer' : 'not-allowed', fontSize: '11px', fontWeight: 500 }}>
                      {editingCueIndex !== null ? 'Update' : 'Add Cue'}
                    </button>
                  </div>
                </div>
              </div>
            );

          case 'response':
            return (
              <div>
                <SectionHeader>Deficit</SectionHeader>
                <OptionGrid columns={2}>
                  {deficitOptions.map(d => (<ChipButton key={d} selected={deficit === d} onClick={() => setDeficit(deficit === d ? null : d)} size="sm">{d}</ChipButton>))}
                </OptionGrid>

                <div style={{ marginTop: '12px' }}>
                  <SectionHeader>Progress</SectionHeader>
                  <OptionGrid columns={3}>
                    {PROGRESS_OPTIONS.map(p => (<ChipButton key={p.id} selected={progress === p.id} onClick={() => setProgress(progress === p.id ? null : p.id)} size="sm">{p.label}</ChipButton>))}
                  </OptionGrid>
                </div>

                <div style={{ marginTop: '12px' }}>
                  <SectionHeader>Tolerance</SectionHeader>
                  <OptionGrid columns={2}>
                    {TOLERANCE_OPTIONS.map(t => (<ChipButton key={t.id} selected={tolerance === t.id} onClick={() => setTolerance(tolerance === t.id ? null : t.id)} size="sm" variant="outline">{t.label}</ChipButton>))}
                  </OptionGrid>
                </div>

                <div style={{ marginTop: '12px' }}>
                  <SectionHeader>Plan for Next Session</SectionHeader>
                  <OptionGrid columns={2}>
                    {PLAN_OPTIONS.map(p => (<ChipButton key={p.id} selected={plan === p.id} onClick={() => setPlan(plan === p.id ? null : p.id)} size="sm" variant="outline">{p.label}</ChipButton>))}
                  </OptionGrid>
                </div>
              </div>
            );

          case 'notes':
            return (
              <div>
                <SectionHeader>Patient Subjective</SectionHeader>
                <OptionGrid columns={3}>
                  {PATIENT_SUBJECTIVE_OPTIONS.map(opt => (<ChipButton key={opt} selected={patientSubjective === opt} onClick={() => setPatientSubjective(patientSubjective === opt ? '' : opt)} size="sm" variant="outline">{opt}</ChipButton>))}
                </OptionGrid>
                <textarea value={patientSubjective} onChange={(e) => setPatientSubjective(e.target.value)} placeholder='Or type custom quote' style={{ width: '100%', padding: '8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '12px', minHeight: '40px', resize: 'vertical', marginTop: '6px', marginBottom: '12px' }} />

                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px', marginBottom: '12px' }}>
                  <div>
                    <SectionHeader>Pain</SectionHeader>
                    <div style={{ display: 'flex', gap: '6px' }}>
                      <select value={painLocation} onChange={(e) => setPainLocation(e.target.value)} style={{ flex: 2, padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">Location...</option>
                        {PAIN_LOCATIONS.map(loc => (<option key={loc} value={loc}>{loc}</option>))}
                      </select>
                      <select value={painRating} onChange={(e) => setPainRating(e.target.value)} style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">0-10</option>
                        {PAIN_RATINGS.map(r => (<option key={r} value={r}>{r}</option>))}
                      </select>
                    </div>
                  </div>
                  <div>
                    <SectionHeader>Vitals</SectionHeader>
                    <div style={{ display: 'flex', gap: '6px' }}>
                      <select value={vitals.hr} onChange={(e) => setVitals(prev => ({ ...prev, hr: e.target.value }))} style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">HR</option>
                        {HR_OPTIONS.map(hr => (<option key={hr} value={hr}>{hr}</option>))}
                      </select>
                      <select value={vitals.o2sat} onChange={(e) => setVitals(prev => ({ ...prev, o2sat: e.target.value }))} style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">O2%</option>
                        {O2SAT_OPTIONS.map(o2 => (<option key={o2} value={o2}>{o2}%</option>))}
                      </select>
                      <select value={vitals.bp} onChange={(e) => setVitals(prev => ({ ...prev, bp: e.target.value }))} style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--border-color)', borderRadius: '4px', fontSize: '11px' }}>
                        <option value="">BP</option>
                        {BP_OPTIONS.map(bp => (<option key={bp} value={bp}>{bp}</option>))}
                      </select>
                    </div>
                  </div>
                </div>

                <div style={{ borderTop: '1px solid var(--border-color)', paddingTop: '12px' }}>
                  <SectionHeader>Performance Observations</SectionHeader>
                  <OptionGrid columns={2}>
                    {getPerformanceQualifiers(activity.parent, activity.child).map(qual => (
                      <ChipButton key={qual} selected={selectedPerformance.includes(qual)} onClick={() => { if (selectedPerformance.includes(qual)) setSelectedPerformance(prev => prev.filter(p => p !== qual)); else setSelectedPerformance(prev => [...prev, qual]); }} size="sm">{qual}</ChipButton>
                    ))}
                  </OptionGrid>

                  <div style={{ marginTop: '12px' }}>
                    <SectionHeader>Session Context</SectionHeader>
                    <OptionGrid columns={2}>
                      {SESSION_CONTEXT_OPTIONS.map(ctx => (
                        <ChipButton key={ctx} selected={selectedContext.includes(ctx)} onClick={() => { if (selectedContext.includes(ctx)) setSelectedContext(prev => prev.filter(c => c !== ctx)); else setSelectedContext(prev => [...prev, ctx]); }} size="sm" variant="outline">{ctx}</ChipButton>
                      ))}
                    </OptionGrid>
                  </div>

                  <div style={{ marginTop: '12px' }}>
                    <SectionHeader>Clinical Reasoning</SectionHeader>
                    <OptionGrid columns={2}>
                      {CLINICAL_REASONING_OPTIONS.map(reason => (
                        <ChipButton key={reason} selected={selectedReasoning.includes(reason)} onClick={() => { if (selectedReasoning.includes(reason)) setSelectedReasoning(prev => prev.filter(r => r !== reason)); else setSelectedReasoning(prev => [...prev, reason]); }} size="sm" variant="outline">{reason}</ChipButton>
                      ))}
                    </OptionGrid>
                  </div>
                </div>
              </div>
            );

          default:
            return null;
        }
      };

      // ============================================
      // MAIN RENDER
      // ============================================

      return (
        <div style={{ height: '100%', display: 'flex', flexDirection: 'column', maxWidth: '900px', margin: '0 auto', padding: '8px 12px' }}>
          {/* HEADER */}
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '8px', flexShrink: 0 }}>
            <h1 style={{ fontSize: '16px', fontWeight: 600 }}>OT Daily Note Builder</h1>
            <div style={{ display: 'flex', gap: '8px', alignItems: 'center' }}>
              <button
                onClick={() => setDarkMode(!darkMode)}
                style={{
                  padding: '4px 10px',
                  background: 'var(--bg-secondary)',
                  border: '1px solid var(--border-color)',
                  borderRadius: '4px',
                  cursor: 'pointer',
                  fontSize: '11px',
                  display: 'flex',
                  alignItems: 'center',
                  gap: '4px'
                }}
              >
                {darkMode ? '☀️' : '🌙'}
              </button>
              <button onClick={handleClear} style={{ padding: '4px 12px', background: 'var(--bg-secondary)', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: 'pointer', fontSize: '11px' }}>Clear</button>
            </div>
          </div>

          {/* PREVIEW - Sticky at top */}
          <div style={{ background: 'var(--bg-secondary)', borderRadius: '8px', border: '1px solid var(--border-color)', marginBottom: '8px', flexShrink: 0 }}>
            <div style={{ padding: '10px 12px', maxHeight: '100px', overflowY: 'auto', fontFamily: "'IBM Plex Mono', monospace", fontSize: '11px', lineHeight: 1.6, color: output ? 'var(--text-primary)' : 'var(--text-muted)' }}>
              {output || 'Start building your note...'}
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '6px 12px', borderTop: '1px solid var(--border-color)', background: 'var(--bg-tertiary)' }}>
              <div style={{ display: 'flex', background: 'var(--bg-secondary)', borderRadius: '4px', padding: '2px' }}>
                <button onClick={() => setOutputStyle('goal')} style={{ padding: '3px 10px', background: outputStyle === 'goal' ? 'var(--accent-primary)' : 'transparent', color: outputStyle === 'goal' ? '#fff' : 'var(--text-muted)', border: 'none', borderRadius: '3px', cursor: 'pointer', fontSize: '10px', fontWeight: 500 }}>Goal-Led</button>
                <button onClick={() => setOutputStyle('activity')} style={{ padding: '3px 10px', background: outputStyle === 'activity' ? 'var(--accent-primary)' : 'transparent', color: outputStyle === 'activity' ? '#fff' : 'var(--text-muted)', border: 'none', borderRadius: '3px', cursor: 'pointer', fontSize: '10px', fontWeight: 500 }}>Activity-Led</button>
              </div>
              <button onClick={handleCopy} style={{ padding: '4px 14px', background: copied ? 'var(--success)' : 'var(--accent-primary)', color: '#fff', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: '11px', fontWeight: 500 }}>{copied ? '✓ Copied' : 'Copy'}</button>
            </div>
          </div>

          {/* STAGE CONTAINER - Fills remaining space */}
          <div style={{ flex: 1, background: 'var(--bg-secondary)', borderRadius: '8px', border: '1px solid var(--border-color)', padding: '12px', marginBottom: '8px', overflowY: 'auto', minHeight: 0 }}>
            {renderStageContent()}
          </div>

          {/* NAV - Fixed at bottom */}
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '8px 12px', background: 'var(--bg-secondary)', borderRadius: '8px', border: '1px solid var(--border-color)', flexShrink: 0 }}>
            <button onClick={handleBack} disabled={currentStep === 0} style={{ padding: '6px 14px', background: currentStep === 0 ? 'var(--bg-tertiary)' : 'var(--bg-secondary)', border: '1px solid var(--border-color)', borderRadius: '4px', cursor: currentStep === 0 ? 'not-allowed' : 'pointer', fontSize: '12px', fontWeight: 500, color: currentStep === 0 ? 'var(--text-muted)' : 'var(--text-primary)' }}>← Back</button>

            <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
              {STEPS.map((step, index) => (
                <button key={step.id} onClick={() => setCurrentStep(index)} style={{ width: '24px', height: '24px', borderRadius: '50%', border: 'none', background: index === currentStep ? 'var(--accent-primary)' : index < currentStep ? 'var(--success)' : 'var(--bg-tertiary)', color: index <= currentStep ? '#fff' : 'var(--text-muted)', fontSize: '10px', fontWeight: 600, cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center' }} title={step.label}>
                  {index < currentStep ? '✓' : index + 1}
                </button>
              ))}
            </div>

            <button onClick={handleNext} disabled={currentStep === STEPS.length - 1 || (STEPS[currentStep].required && !canProceed())} style={{ padding: '6px 14px', background: currentStep === STEPS.length - 1 || (STEPS[currentStep].required && !canProceed()) ? 'var(--bg-tertiary)' : 'var(--accent-primary)', color: currentStep === STEPS.length - 1 || (STEPS[currentStep].required && !canProceed()) ? 'var(--text-muted)' : '#fff', border: 'none', borderRadius: '4px', cursor: currentStep === STEPS.length - 1 || (STEPS[currentStep].required && !canProceed()) ? 'not-allowed' : 'pointer', fontSize: '12px', fontWeight: 500 }}>
              {currentStep === STEPS.length - 1 ? 'Done' : 'Continue →'}
            </button>
          </div>
        </div>
      );
    };

    ReactDOM.render(<OTDailyNoteBuilder />, document.getElementById('root'));
  </script>
</body>
</html>
